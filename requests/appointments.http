  "invoiceDetails": "Oil change service"
}

### Get Appointment Status Log
GET http://localhost:4000/api/v1/appointments/6e3bc817-f492-4d9f-a842-28d4399e0143/status-log

### Get Tracking Appointments
GET http://localhost:4000/api/v1/appointments/tracking?status=PENDING